   ],
   "source": [
    "import re\n",
    "\n",
    "text = input(\"Введите текст\")\n",
    "\n",
    "pattern = r'\\b[A-Z][a-zA-Z]*(?:\\d{4}|\\d{2})\\b'\n",
    "\n",
    "words = re.findall(pattern, text)\n",
    "\n",
    "print(words)"
   ]
