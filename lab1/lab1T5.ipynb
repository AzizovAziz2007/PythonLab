     "text": [
      "Введите предложение:  город Донецк очень красивый, но жаль, что Кальмиус грязный\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "город ДОНЕЦК очень красивый, но жаль, что КАЛЬМИУС грязный\n"
     ]
    }
   ],
   "source": [
    "text = input(\"Введите предложение: \")\n",
    "\n",
    "words = text.split()\n",
    "\n",
    "result_words = []\n",
    "\n",
    "for word in words:\n",
    "    if word[0].isupper():\n",
    "        result_words.append(word.upper())\n",
    "    else:\n",
    "        result_words.append(word)\n",
    "\n",
    "new_text = \" \".join(result_words)\n",
    "\n",
    "print(new_text)"
   ]
  }
 ],
