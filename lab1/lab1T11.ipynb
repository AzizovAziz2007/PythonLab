   "source": [
    "def frange(start, stop, step):\n",
    "    current = start\n",
    "    while current < stop:\n",
    "        yield current\n",
    "        current += step\n",
    "\n",
    "for x in frange(1, 5, 0.1):\n",
    "    print(x)"
   ]
