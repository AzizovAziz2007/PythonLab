    "numbers = [1, 2, 3, 4, 5]\n",
    "\n",
    "is_increasing = True\n",
    "\n",
    "for i in range(1, len(numbers)):\n",
    "    if numbers[i] <= numbers[i-1]:\n",
    "        is_increasing = False\n",
    "        break\n",
    "print(is_increasing)"
