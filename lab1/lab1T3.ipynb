   "source": [
    "card_num = input(\"Введите номер дебетовой карты: \")\n",
    "\n",
    "if len(card_num) != 16:\n",
    "    print(\"Ошмбка! Номер должен состоять из 16 цифр!\")\n",
    "else:\n",
    "    first_four = card_num[:4]\n",
    "    last_four = card_num[-4:]\n",
    "\n",
    "print(f\"{first_four} **** **** {last_four}\")"
   ]
