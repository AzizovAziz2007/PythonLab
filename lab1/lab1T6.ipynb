   "source": [
    "text = input(\"Введите текст: \")\n",
    "\n",
    "symbols = []\n",
    "\n",
    "for char in text:\n",
    "    if text.count(char) == 1 and char != \" \":\n",
    "        symbols.append(char)\n",
    "\n",
    "print(f\"Уникальные символы: {symbols}\")"
   ]
