   "source": [
    "def extra_enumerate(x):\n",
    "    total = sum(x)\n",
    "    cum = 0\n",
    "\n",
    "    for i, elem in enumerate(x):\n",
    "        cum += elem\n",
    "        frac = cum / total\n",
    "\n",
    "        yield i, elem, cum, frac\n",
    "\n",
    "x = [1, 3, 4, 2]\n",
    "for i, elem, cum, frac in extra_enumerate(x):\n",
    "    print(elem, cum, frac)"
   ]
  }
 ],
