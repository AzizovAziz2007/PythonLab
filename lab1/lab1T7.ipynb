   "source": [
    "urls = [\"www.google\", \"yandex.ru\", \"www.python.org\"]\n",
    "\n",
    "step1 = [\"http://\" + url if url.startswith(\"www\") else url for url in urls]\n",
    "\n",
    "final_step = [url if url.endswith(\".com\") else url + \".com\" for url in step1]\n",
    "\n",
    "print(final_step)"
   ]
